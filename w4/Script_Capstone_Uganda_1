#Monocyte Transcription Network and TST Status in Uganda
#Source: 	Seshadri C, Sedaghat N, Campo M, Peterson G et al. Transcriptional networks are associated with resistance to Mycobacterium tuberculosis infection. PLoS One 2017;12(4):e0175844. PMID: 28414762
#GSE: GSE76873
#GPL: 	GPL6947	Illumina HumanHT-12 V3.0 expression beadchip

#1. Running Library
```{r}
library(GEOquery)
library(limma)
library(pheatmap)
library(ggplot2)
library(dplyr)
library(illuminaHumanv4.db)
library(AnnotationDbi)
library(umap)
```

#2. Ambil data
```{r}
gset<-getGEO("GSE76873", GSEMatrix = TRUE, AnnotGPL = TRUE)[[1]]
```
#3. Ektraksi Data Ekspresi
```{r}
ex <- exprs(gset)
```
#4. Hitung kuantil data dan ubah ke format numeric
```{r}
qx <- as.numeric(quantile(ex, c(0, 0.25, 0.5, 0.75, 0.99, 1), na.rm = TRUE))
```
#5. Log Transformasi
```{r}
#Buat Fungsi
LogTransform <- (qx[5] > 100) || (qx[6] - qx[1] > 50 && qx[2] > 0)

#Run Fungsi
if (LogTransform) {
# Nilai <= 0 tidak boleh di-log, maka diubah menjadi NA
ex[ex <= 0] <- NA
ex <- log2(ex)
}
```
#6. Mendefinisikan kelompok sampel
#Kelompok sampel: Cohort (grup TST_Neg dan TST_pos)
```{r}
group_info <- pData(gset)[["characteristics_ch1.1"]]
groups <- make.names(group_info)
gset$group <- factor(groups)
nama_grup <- levels(gset$group)
print(nama_grup)
```
#7. Design Matrix (Kerangka Statistik)
```{r}
#bikin model matriks
design <- model.matrix(~0 + gset$group)

#penamaan grup dalam perbandingan biologis
colnames(design) <- levels(gset$group)
TSTNegatif<- nama_grup [1]
TSTPositif <- nama_grup [2]

#perbandingan biologis
contrast_formula <- paste(TSTNegatif, "-", TSTPositif)
print(paste("Kontras yang dianalisis", contrast_formula))
```
#8. DEG dengan LIMMA
```{r}
#Bikin model linear setiap gen
fit <- lmFit(ex, design)

#perbandingan biologis
contrast_matrix <- makeContrasts(contrasts = contrast_formula, levels= design)

#menerapkan kontras ke model
fit2 <- contrasts.fit(fit, contrast_matrix)

#Ebayes
fit2 <- eBayes(fit2)
print(fit2)

#DEG, pvalue pada penelitian ini adalah 
topTableResults <- topTable(
fit2,
adjust = "fdr",
sort.by = "B",
number = 50
)
head(topTableResults)

```
#9. Anotasi Nama Gen
```{r}
probe_ids <- rownames(topTableResults)
gene_annotation <- AnnotationDbi::select(
illuminaHumanv4.db,
keys = probe_ids,
columns = c("SYMBOL", "GENENAME"),
keytype = "PROBEID")
topTableResults$PROBEID <- rownames(topTableResults)
topTableResults <- merge(
topTableResults,
gene_annotation,
by = "PROBEID",
all.x = TRUE
)
head(topTableResults[, c("PROBEID", "SYMBOL", "GENENAME")])
```
